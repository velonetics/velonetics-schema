{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://velonetics.io/schema/v2.2/plugin/http-client.json",
  "title": "HTTP client plugins.\n\nSee: https://velonetics.io/docs/extending/injecting-plugins/",
  "type": "object",
  "properties": {
    "name": {
      "$id": "#plugin/http-client",
      "title": "Plugin name",
      "description": "The name of the plugin to load. Only one plugin is supported per backend.\n\nSee: https://velonetics.io/docs/extending/injecting-plugins/",
      "examples": [ "no-redirect", "http-logger", "static-filesystem" ],
      "type": "string"
    }
  }
}

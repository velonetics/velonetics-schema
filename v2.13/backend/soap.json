{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://velonetics.io/schema/v2.13/backend/soap.json",
  "title": "SOAP Template modifier",
  "description": "Build and modify requests to communicate with SOAP services. Available in Velonetics CE.\n\nSee: https://velonetics.io/docs/backends/soap/",
  "type": "object",
  "oneOf": [
    {
      "required": [ "path" ]
    },
    {
      "required": [ "template" ]
    },
    {
      "required": [ "wsdl" ],
      "properties": {
        "wsdl": {
          "required": [ "generate_template" ],
          "properties": {
            "generate_template": {
              "const": true
            }
          }
        }
      }
    }
  ],
  "properties": {
    "content_type": {
      "title": "Content-Type",
      "description": "The Content-Type sent to the SOAP server.",
      "examples": [ "application/xml", "text/xml" ],
      "default": "text/xml",
      "type": "string"
    },
    "debug": {
      "title": "Enable debug",
      "default": false,
      "type": "boolean"
    },
    "path": {
      "title": "Path to template",
      "examples": [ "./path/to.xml" ],
      "type": "string"
    },
    "template": {
      "title": "Template",
      "description": "Inline base64-encoded Go template XML body.",
      "type": "string"
    },
    "soap_action": {
      "title": "SOAPAction",
      "description": "SOAPAction HTTP header value sent to the SOAP server (SOAP 1.1).",
      "type": "string"
    },
    "watch_template": {
      "title": "Watch template file",
      "description": "When true and path is set, reload the template when the file changes.",
      "default": false,
      "type": "boolean"
    },
    "reload_interval": {
      "title": "Reload interval",
      "description": "Polling interval to reload path-based templates (e.g. 5s).",
      "examples": [ "5s", "30s" ],
      "type": "string"
    },
    "wsdl": {
      "title": "WSDL",
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "service": {
          "type": "string"
        },
        "port": {
          "type": "string"
        },
        "operation": {
          "type": "string"
        },
        "generate_template": {
          "default": false,
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "ws_security": {
      "title": "WS-Security",
      "type": "object",
      "properties": {
        "username_token": {
          "type": "object",
          "properties": {
            "username": {
              "type": "string"
            },
            "password": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "saml_assertion": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "x509": {
          "type": "object",
          "properties": {
            "cert_path": {
              "type": "string"
            },
            "key_path": {
              "type": "string"
            },
            "key_password": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "patternProperties": {
    "^[@$_#]": true
  },
  "additionalProperties": false
}

{
  "description": "response-headers",
  "target": "https://velonetics.io/schema/v2.7/modifier/response-headers.json",
  "tests": [
    {
      "description": "happy case",
      "data": {
        "add": {
          "X-Hello": [
            "World"
          ]
        },
        "replace": {
          "Cache-Control": [
            "no-store"
          ],
          "Vary": [
            "foo",
            "bar",
            "foobar"
          ]
        },
        "delete": [
          "X-Velonetics",
          "X-Velonetics-Completed"
        ]
      },
      "valid": true
    },
    {
      "description":"empty modifiers are not valid",
      "data": {
        "add": {}
      },
      "valid": false
    },
    {
      "description":"empty declaration is not allowed",
      "data": {},
      "valid": false
    }
  ]
}
{
  "description": "response-headers",
  "target": "https://pucora.in/schema/v2.12/modifier/response-headers.json",
  "tests": [
    {
      "description": "happy case",
      "data": {
        "add": {
          "X-Hello": [
            "World"
          ]
        },
        "replace": {
          "Cache-Control": [
            "no-store"
          ],
          "Vary": [
            "foo",
            "bar",
            "foobar"
          ]
        },
        "delete": [
          "X-Pucora",
          "X-Pucora-Completed"
        ],
        "rename": {
          "Header-A": "Header-A-Renamed"
        }
      },
      "valid": true
    },
    {
      "description":"empty modifiers are not valid",
      "data": {
        "add": {}
      },
      "valid": false
    },
    {
      "description":"empty declaration is not allowed",
      "data": {},
      "valid": false
    }
  ]
}
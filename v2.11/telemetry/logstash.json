{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pucora.in/schema/v2.11/telemetry/logstash.json",
  "title": "Logstash",
  "description": "Enables logstash when the extra_config \"telemetry/logging\" is also present.\n\nSee: https://pucora.in/docs/logging/logstash/",
  "type": "object",
  "required": [ "enabled" ],
  "properties": {
    "enabled": {
      "$id": "#enabled",
      "title": "Enabled",
      "default": true,
      "type": "boolean"
    }
  },
  "patternProperties": {
    "^[@$_#]": {}
  },
  "additionalProperties": false
}
